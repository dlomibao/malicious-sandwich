# Copy to backend/.env and fill in.

# Which provider to use when the request doesn't specify one.
DEFAULT_PROVIDER=anthropic

# At least one of these must be set, matching DEFAULT_PROVIDER.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# CORS — comma-separated origins permitted to call the API.
ALLOWED_ORIGINS=http://localhost:5173

# Per-IP sliding-window rate limit (applies to /api/llm and /api/stats/run).
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_S=60

# SQLite location for the stats store.
STATS_DB_PATH=./sandwich.db
